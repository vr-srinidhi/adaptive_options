ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here

# Security — generate these before going to production
# openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_TOKEN_ENCRYPTION_KEY=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Set to "production" on Railway to enable HSTS and fail-fast secret checks
ENVIRONMENT=development

# Historical backtest data
# LOCAL_DATA_PATH: absolute path to the directory containing spot/, options/, vix/, futures/ subdirs
# This is mounted as /data/historical inside the backend container (read-only).
LOCAL_DATA_PATH=/Users/h1552601/Documents/adaptive-options-datasource/data
DATA_SOURCE_PATH=/data/historical
